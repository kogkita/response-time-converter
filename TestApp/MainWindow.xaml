<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Test Utilities"
        Height="720"
        Width="1280"
        MinHeight="540"
        MinWidth="760"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B93A5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2130"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1A2540"/>
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon-only remove button for file list rows -->
        <Style x:Key="RemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D1F1F"/>
                                <Setter Property="Foreground" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Caption button (min/max/close) -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B0251A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark-themed ComboBox style for nmon dropdowns -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#161B2A"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderBrush" Value="#252D42"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1E2338"/>
                        <Setter Property="Foreground" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E3A8A"/>
                                <Setter Property="Foreground" Value="#93C5FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border gives Win11 rounded corners + shadow -->
    <Border Background="#0F1117"
            CornerRadius="12"
            BorderBrush="#2A2F3E"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="6" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ TITLE BAR ══════════════════════ -->
            <Border Grid.Row="0"
                    Background="#0A0D14"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <TextBlock Text="&#x23F1;"
                                   FontSize="14"
                                   Foreground="#60A5FA"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Performance Test Utilities"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#CBD5E1"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE921;"
                                Click="MinimizeWindow_Click"
                                ToolTip="Minimize"/>
                        <Button x:Name="MaxRestoreBtn"
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE922;"
                                Click="MaxRestoreWindow_Click"
                                ToolTip="Maximize"/>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;"
                                Click="CloseWindow_Click"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════ BODY ══════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#0A0D14" CornerRadius="0,0,0,12">
                    <DockPanel>

                        <Border DockPanel.Dock="Top" Padding="20,18,20,16">
                            <StackPanel>
                                <TextBlock Text="Performance Test"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Utilities"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#60A5FA"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E2130" Margin="12,0"/>

                        <!-- ── JMeter Tools group ── -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="JMETER TOOLS"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#3D4560"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,14,0,4"/>

                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                            <Button x:Name="NavConvert"
                                    Style="{StaticResource NavButtonActiveStyle}"
                                    Click="NavConvert_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Convert Response Times" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavJTL"
                                    Style="{StaticResource NavButtonStyle}"
                                    Click="NavJTL_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C4;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="JTL File Processing" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavCompare"
                                    Style="{StaticResource NavButtonStyle}"
                                    Click="NavCompare_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x21C4;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Run Comparison" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── System Monitoring group ── -->
                        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E2130" Margin="12,8"/>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="SYSTEM MONITORING"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#3D4560"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,4,0,4"/>

                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                            <Button x:Name="NavBLG"
                                    Style="{StaticResource NavButtonStyle}"
                                    Click="NavBLG_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C8;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="BLG File Conversion" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavNmon"
                                    Style="{StaticResource NavButtonStyle}"
                                    Click="NavNmon_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F5A5;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="nmon Analyzer" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="v1.2.0"
                                   FontSize="11"
                                   Foreground="#2D3450"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,0,0,16"/>

                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="#1A1F2E"/>

                <!-- CONTENT -->
                <Grid Grid.Column="2" Background="#0F1117">

                    <Grid x:Name="PageConvert" Visibility="Visible">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <!-- Heading -->
                                <RowDefinition Height="Auto"/>
                                <!-- Browse row -->
                                <RowDefinition Height="Auto"/>
                                <!-- File list -->
                                <RowDefinition Height="Auto"/>
                                <!-- Drop zone -->
                                <RowDefinition Height="*"/>
                                <!-- Run button -->
                                <RowDefinition Height="Auto"/>
                                <!-- Log panel -->
                                <RowDefinition Height="Auto" MaxHeight="150"/>
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Convert Response Times"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Import one or more JMeter CSV(.csv) reports and export formatted Excel workbooks with charts."
                                           FontSize="12.5"
                                           Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Browse row -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- File count pill -->
                                <Border Grid.Column="0"
                                        Background="#161B2A"
                                        BorderBrush="#252D42"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="40">
                                    <TextBlock x:Name="FileCountLabel"
                                               Text="No files selected"
                                               Foreground="#8B93A5"
                                               FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center"
                                               Padding="12,0"/>
                                </Border>

                                <!-- Browse button -->
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Width="96"
                                        Height="40"
                                        Margin="10,0,0,0"
                                        Click="BrowseFile_Click"/>

                                <!-- Clear All button (hidden when no files) -->
                                <Button x:Name="ClearAllButton"
                                        Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151"
                                        Foreground="#9CA3AF"
                                        FontSize="12"
                                        Width="80"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        Click="ClearAll_Click"/>
                            </Grid>

                            <!-- Selected file list -->
                            <Border Grid.Row="2"
                                    Background="#0A0D18"
                                    BorderBrush="#1A2030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxHeight="160"
                                    Margin="0,0,0,10"
                                    Padding="4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="FileListPanel" Margin="2"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Drop zone -->
                            <Border Grid.Row="3"
                                    x:Name="DropZone"
                                    AllowDrop="True"
                                    Drop="FileDropped"
                                    DragEnter="DropZone_DragEnter"
                                    DragLeave="DropZone_DragLeave"
                                    Background="#0D1020"
                                    BorderBrush="#1E2640"
                                    BorderThickness="1.5"
                                    CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2B07;"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Foreground="#2D3A5A"/>
                                    <TextBlock Text="Drag &amp; drop CSV files here"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Multiple files supported — each gets its own Excel output"
                                               FontSize="11.5"
                                               Foreground="#252D42"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- Run button row -->
                            <!-- Run button row -->
                            <Grid Grid.Row="4" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
            Content="Run Processing"
            Style="{StaticResource ActionButtonStyle}"
            Background="#16A34A"
            Foreground="White"
            FontSize="14"
            FontWeight="SemiBold"
            Width="180"
            Height="42"
            Click="RunProcessing_Click"/>

                                <!-- Include Charts checkbox -->
                                <Border Grid.Column="1"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="IncludeChartsCheckbox"
                  IsChecked="False"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Include Charts" Foreground="#8B93A5"/>
                <Run Text="  —  add latency chart sheet to output" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>

                                <!-- Club into one file checkbox -->
                                <Border Grid.Column="2"
                                  Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="ClubOutputCheckbox"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Club into one file" Foreground="#8B93A5"/>
                <Run Text="  —  all inputs merged into a single Excel workbook" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>
                            </Grid>

                            <!-- Log panel -->
                            <Border Grid.Row="5" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                    Padding="10,8" Visibility="Collapsed"
                                    x:Name="ConvertLogPanel">
                                <StackPanel>
                                    <ProgressBar x:Name="ConvertProgress" Height="3"
                                                 Background="#1A2030" Foreground="#2563EB"
                                                 BorderThickness="0" IsIndeterminate="True"
                                                 Margin="0,0,0,6"/>
                                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="ConvertLog" Text=""
                                                   Foreground="#8B93A5" FontSize="11.5"
                                                   FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                    <Grid x:Name="PageJTL" Visibility="Collapsed">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MaxHeight="150"/>
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="JTL File Processing"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Import one or more JMeter JTL(.jtl) files and export formatted Excel workbooks with summary stats and charts."
                                           FontSize="12.5"
                                           Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Browse row -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#161B2A"
                                        BorderBrush="#252D42"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="40">
                                    <TextBlock x:Name="JTLFileCountLabel"
                                               Text="No files selected"
                                               Foreground="#8B93A5"
                                               FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center"
                                               Padding="12,0"/>
                                </Border>

                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Width="96"
                                        Height="40"
                                        Margin="10,0,0,0"
                                        Click="JTLBrowseFile_Click"/>

                                <Button x:Name="JTLClearAllButton"
                                        Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151"
                                        Foreground="#9CA3AF"
                                        FontSize="12"
                                        Width="80"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        Click="JTLClearAll_Click"/>
                            </Grid>

                            <!-- Selected file list -->
                            <Border Grid.Row="2"
                                    Background="#0A0D18"
                                    BorderBrush="#1A2030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxHeight="160"
                                    Margin="0,0,0,10"
                                    Padding="4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="JTLFileListPanel" Margin="2"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Drop zone -->
                            <Border Grid.Row="3"
                                    x:Name="JTLDropZone"
                                    AllowDrop="True"
                                    Drop="JTLFileDropped"
                                    DragEnter="JTLDropZone_DragEnter"
                                    DragLeave="JTLDropZone_DragLeave"
                                    Background="#0D1020"
                                    BorderBrush="#1E2640"
                                    BorderThickness="1.5"
                                    CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2B07;"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Foreground="#2D3A5A"/>
                                    <TextBlock Text="Drag &amp; drop JTL files here"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Supports .jtl JMeter result files — multiple files get their own Excel output"
                                               FontSize="11.5"
                                               Foreground="#252D42"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- Run button row -->
                            <!-- Run button row -->
                            <Grid Grid.Row="4" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
            Content="Run Processing"
            Style="{StaticResource ActionButtonStyle}"
            Background="#16A34A"
            Foreground="White"
            FontSize="14"
            FontWeight="SemiBold"
            Width="180"
            Height="42"
            Click="JTLRunProcessing_Click"/>

                                <!-- Include Charts checkbox -->
                                <Border Grid.Column="1"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="JTLIncludeChartsCheckbox"
                  IsChecked="False"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Include Charts" Foreground="#8B93A5"/>
                <Run Text="  —  add latency chart sheet to output" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>

                                <!-- Club into one file checkbox -->
                                <Border Grid.Column="2"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="JTLClubOutputCheckbox"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Club into one file" Foreground="#8B93A5"/>
                <Run Text="  —  all inputs merged into a single Excel workbook" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>
                            </Grid>

                            <!-- Log panel -->
                            <Border Grid.Row="5" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                    Padding="10,8" Visibility="Collapsed"
                                    x:Name="JTLLogPanel">
                                <StackPanel>
                                    <ProgressBar x:Name="JTLProgress" Height="3"
                                                 Background="#1A2030" Foreground="#2563EB"
                                                 BorderThickness="0" IsIndeterminate="True"
                                                 Margin="0,0,0,6"/>
                                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="JTLLog" Text=""
                                                   Foreground="#8B93A5" FontSize="11.5"
                                                   FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                    <!-- ═══════════════ BLG FILE CONVERSION PAGE ═══════════════ -->
                    <Grid x:Name="PageBLG" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="36,28,36,28">
                                <Grid.RowDefinitions>
                                    <!-- Heading -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Browse row -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- File list -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Server type + counter options panel -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Command preview -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Drop zone -->
                                    <RowDefinition Height="Auto" MinHeight="120"/>
                                    <!-- Run button -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Log panel -->
                                    <RowDefinition Height="Auto" MaxHeight="150"/>
                                </Grid.RowDefinitions>

                                <!-- Heading -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="BLG File Conversion"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Convert Windows Performance Monitor .blg files to CSV using relog.exe"
                                           FontSize="12.5" Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Browse row -->
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Height="40">
                                        <TextBlock x:Name="BLGFileCountLabel" Text="No files selected"
                                               Foreground="#8B93A5" FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB" Foreground="White"
                                        FontSize="13" FontWeight="SemiBold"
                                        Width="96" Height="40" Margin="10,0,0,0"
                                        Click="BLGBrowseFile_Click"/>
                                    <Button x:Name="BLGClearAllButton" Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151" Foreground="#9CA3AF"
                                        FontSize="12" Width="80" Height="40"
                                        Margin="8,0,0,0" Visibility="Collapsed"
                                        Click="BLGClearAll_Click"/>
                                </Grid>

                                <!-- Selected file list -->
                                <Border Grid.Row="2" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8"
                                    MaxHeight="140" Margin="0,0,0,12" Padding="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="BLGFileListPanel" Margin="2"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- ── Options panel ── -->
                                <Border Grid.Row="3" Background="#0D1020" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="16,14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="CONVERSION OPTIONS"
                                               FontSize="10" FontWeight="Bold" Foreground="#3D4560"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- LEFT: Server type -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="SERVER TYPE" Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,8"/>

                                                <Border Background="#161B2A" BorderBrush="#252D42"
                                                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                                                    <StackPanel>
                                                        <!-- App Server -->
                                                        <RadioButton x:Name="BLGRadioApp"
                                                                 GroupName="BLGServerType"
                                                                 IsChecked="True"
                                                                 Foreground="#CBD5E1" FontSize="12.5"
                                                                 FontFamily="Segoe UI Variable, Segoe UI"
                                                                 Cursor="Hand" Margin="0,0,0,8"
                                                                 Checked="BLGServerType_Changed">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="App Server" Foreground="#CBD5E1" FontSize="12.5"/>
                                                                <TextBlock Text="  — OS + process counters" Foreground="#3D4560" FontSize="11" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </RadioButton>
                                                        <!-- DB Server -->
                                                        <RadioButton x:Name="BLGRadioDb"
                                                                 GroupName="BLGServerType"
                                                                 Foreground="#CBD5E1" FontSize="12.5"
                                                                 FontFamily="Segoe UI Variable, Segoe UI"
                                                                 Cursor="Hand"
                                                                 Checked="BLGServerType_Changed">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="DB Server" Foreground="#CBD5E1" FontSize="12.5"/>
                                                                <TextBlock Text="  — OS + SQL Server counters" Foreground="#3D4560" FontSize="11" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </RadioButton>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- RIGHT: Custom counter file override -->
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="CUSTOM COUNTER FILE" Foreground="#8B93A5" FontSize="11"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                    <TextBlock Text="  (optional — overrides server type template)"
                                                           Foreground="#3D4560" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#161B2A" BorderBrush="#252D42"
                                                        BorderThickness="1" CornerRadius="6" Height="36">
                                                        <TextBlock x:Name="BLGCounterFileLabel"
                                                               Text="Using default template"
                                                               Foreground="#4A5568" FontSize="11.5"
                                                               FontFamily="Consolas, Segoe UI Mono"
                                                               VerticalAlignment="Center" Padding="10,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                    <Button Grid.Column="1" Content="Browse…"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#374151" Foreground="#9CA3AF"
                                                        FontSize="12" Width="80" Height="36"
                                                        Margin="8,0,0,0"
                                                        Click="BLGCounterFileBrowse_Click"/>
                                                    <Button x:Name="BLGCounterFileClearBtn" Grid.Column="2"
                                                        Content="✕"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#3D1F1F" Foreground="#F87171"
                                                        FontSize="12" Width="36" Height="36"
                                                        Margin="6,0,0,0" Visibility="Collapsed"
                                                        Click="BLGCounterFileClear_Click"
                                                        ToolTip="Remove custom counter file — revert to default template"/>
                                                </Grid>

                                                <!-- Counter preview list -->
                                                <Border Background="#0A0D14" BorderBrush="#1A2030"
                                                    BorderThickness="1" CornerRadius="6"
                                                    MaxHeight="80" Margin="0,8,0,0" Padding="2">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <ItemsControl x:Name="BLGCounterPreviewList" Margin="6,4">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}"
                                                                           Foreground="#4A6080"
                                                                           FontSize="10.5"
                                                                           FontFamily="Consolas, Segoe UI Mono"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Command preview ── -->
                                <Border Grid.Row="4" Background="#060810" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="14,10" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="COMMAND PREVIEW"
                                               FontSize="10" FontWeight="Bold" Foreground="#3D4560"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="BLGCommandPreview"
                                               Text="relog &quot;&lt;file.blg&gt;&quot; -cf &quot;detailed_counters.txt&quot; -f CSV -o &quot;&lt;file&gt;.csv&quot;"
                                               Foreground="#4ADE80" FontSize="11.5"
                                               FontFamily="Consolas, Segoe UI Mono"
                                               TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Drop zone -->
                                <Border Grid.Row="5"
                                    x:Name="BLGDropZone" AllowDrop="True"
                                    Drop="BLGFileDropped"
                                    DragEnter="BLGDropZone_DragEnter"
                                    DragLeave="BLGDropZone_DragLeave"
                                    Background="#0D1020" BorderBrush="#1E2640"
                                    BorderThickness="1.5" CornerRadius="10"
                                    MinHeight="120" Margin="0,0,0,0">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2B07;" FontSize="28"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" Foreground="#2D3A5A"/>
                                        <TextBlock Text="Drag &amp; drop BLG files here"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                        <TextBlock Text="Accepts .blg Windows Performance Monitor binary log files"
                                               FontSize="11.5" Foreground="#252D42"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    </StackPanel>
                                </Border>

                                <!-- Run button row -->
                                <Grid Grid.Row="6" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                        Content="Run Conversion"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#16A34A" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold"
                                        Width="180" Height="42"
                                        Click="BLGRunProcessing_Click"/>
                                    <TextBlock Grid.Column="1"
                                           x:Name="BLGStatusLabel"
                                           Text=""
                                           Foreground="#4A5568" FontSize="12"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center" Margin="16,0,0,0"
                                           TextWrapping="Wrap"/>
                                </Grid>

                                <!-- Log panel -->
                                <Border Grid.Row="7" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                        Padding="10,8" Visibility="Collapsed"
                                        x:Name="BLGLogPanel">
                                    <StackPanel>
                                        <ProgressBar x:Name="BLGProgress" Height="3"
                                                     Background="#1A2030" Foreground="#2563EB"
                                                     BorderThickness="0" IsIndeterminate="True"
                                                     Margin="0,0,0,6"/>
                                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="BLGLog" Text=""
                                                       Foreground="#8B93A5" FontSize="11.5"
                                                       FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- ═══════════════ NMON ANALYZER PAGE ═══════════════ -->
                    <Grid x:Name="PageNmon" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="36,28,36,28">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto" MaxHeight="150"/>
                                </Grid.RowDefinitions>

                                <!-- Heading -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="nmon Analyzer"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Analyse NMON files using the nmon_analyser_v69 Excel macro engine"
                                           FontSize="13" Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- File selection row -->
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Height="40">
                                        <TextBlock x:Name="NmonFileCountLabel" Text="No files selected"
                                               Foreground="#8B93A5" FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB" Foreground="White"
                                        FontSize="13" FontWeight="SemiBold"
                                        Width="96" Height="40" Margin="10,0,0,0"
                                        Click="NmonBrowseFile_Click"/>
                                    <Button x:Name="NmonClearAllButton" Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151" Foreground="#9CA3AF"
                                        FontSize="12" Width="80" Height="40"
                                        Margin="8,0,0,0" Visibility="Collapsed"
                                        Click="NmonClearAll_Click"/>
                                </Grid>

                                <!-- File list -->
                                <Border Grid.Row="2" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8"
                                    MaxHeight="120" Margin="0,0,0,14" Padding="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="NmonFileListPanel" Margin="2"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- ── Analyser Options ── -->
                                <Border Grid.Row="3" Background="#0D1020" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="ANALYSER OPTIONS"
                                               FontSize="10" FontWeight="Bold" Foreground="#3D4560"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- GRAPHS -->
                                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,10">
                                                <TextBlock Text="GRAPHS" Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="NmonGraphsCombo"
                                                      Style="{StaticResource DarkComboBoxStyle}">
                                                    <ComboBoxItem Content="ALL – CHARTS" IsSelected="True" Tag="ALL|CHARTS"/>
                                                    <ComboBoxItem Content="ALL – PICTURES" Tag="ALL|PICTURES"/>
                                                    <ComboBoxItem Content="LIST – CHARTS" Tag="LIST|CHARTS"/>
                                                    <ComboBoxItem Content="LIST – PICTURES" Tag="LIST|PICTURES"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- MERGE -->
                                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,10">
                                                <TextBlock Text="MERGE" Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="NmonMergeCombo"
                                                      Style="{StaticResource DarkComboBoxStyle}">
                                                    <ComboBoxItem Content="NO" IsSelected="True"/>
                                                    <ComboBoxItem Content="YES"/>
                                                    <ComboBoxItem Content="TOP"/>
                                                    <ComboBoxItem Content="KEEP"/>
                                                    <ComboBoxItem Content="ONLY"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- INTERVALS -->
                                            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,10">
                                                <TextBlock Text="INTERVALS (first / last)" Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NmonIntervalFirst" Grid.Column="0"
                                                         Text="1" Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="32" Padding="8,0"/>
                                                    <TextBox x:Name="NmonIntervalLast" Grid.Column="2"
                                                         Text="999999" Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="32" Padding="8,0"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Checkboxes row -->
                                            <WrapPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,4">
                                                <CheckBox x:Name="NmonEssChk" IsChecked="True" Margin="0,0,20,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="ESS" Foreground="#8B93A5"/>
                                                <Run Text="  additional ESS analysis" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                                <CheckBox x:Name="NmonScatterChk" IsChecked="True" Margin="0,0,20,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="SCATTER" Foreground="#8B93A5"/>
                                                <Run Text="  TOP CPU% by PID chart" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                                <CheckBox x:Name="NmonBigdataChk" IsChecked="True" Margin="0,0,20,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="BIGDATA" Foreground="#8B93A5"/>
                                                <Run Text="  support &gt;1M rows" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                                <CheckBox x:Name="NmonLinuxCpuChk" IsChecked="False" Margin="0,0,20,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="SHOWLINUXCPUUTIL" Foreground="#8B93A5"/>
                                                <Run Text="  all CPUUTILnnn sheets" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                                <CheckBox x:Name="NmonReorderChk" IsChecked="True" Margin="0,0,20,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="REORDER" Foreground="#8B93A5"/>
                                                <Run Text="  reorder sheets" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                                <CheckBox x:Name="NmonSortDefaultChk" IsChecked="True" Margin="0,0,0,6"
                                                      Foreground="#8B93A5" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI" Cursor="Hand">
                                                    <TextBlock><Run Text="SORTDEFAULT" Foreground="#8B93A5"/>
                                                <Run Text="  sort default graphs" Foreground="#3D4560" FontSize="11"/></TextBlock>
                                                </CheckBox>
                                            </WrapPanel>

                                            <!-- LIST (sheet filter) -->
                                            <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,12,0">
                                                <TextBlock Text="LIST  (comma-separated sheet names, used when GRAPHS = LIST)"
                                                       Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <TextBox x:Name="NmonListBox"
                                                     Text="CPU_ALL,DISKBUSY,ESS*,EMC*,FAST*,LPAR,MEM*,NET,PAGE,PROC,TOP"
                                                     Background="#161B2A" Foreground="#CBD5E1"
                                                     BorderBrush="#252D42" FontSize="11" Height="32" Padding="8,0"/>
                                            </StackPanel>

                                            <!-- OUTDIR -->
                                            <StackPanel Grid.Column="2" Grid.Row="2" Margin="0,4,0,0">
                                                <TextBlock Text="OUTPUT DIR  (blank = same as input)"
                                                       Foreground="#8B93A5" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NmonOutDirBox" Grid.Column="0"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="11" Height="32" Padding="8,0"/>
                                                    <Button Grid.Column="1" Content="…"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#374151" Foreground="#9CA3AF"
                                                        Width="32" Height="32" Margin="6,0,0,0"
                                                        Click="NmonOutDirBrowse_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- XLSM path -->
                                <Border Grid.Row="4" Background="#0D1020" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="NMON ANALYSER XLSM PATH"
                                               FontSize="10" FontWeight="Bold" Foreground="#3D4560"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="NmonXlsmPathBox" Grid.Column="0"
                                                 Background="#161B2A" Foreground="#CBD5E1"
                                                 BorderBrush="#252D42" FontSize="12" Height="32" Padding="8,0"
                                                 ToolTip="Path to nmon_analyser_v69_2.xlsm"/>
                                            <Button Grid.Column="1" Content="Browse…"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#374151" Foreground="#9CA3AF"
                                                FontSize="12" Width="90" Height="32" Margin="8,0,0,0"
                                                Click="NmonXlsmBrowse_Click"/>
                                        </Grid>
                                        <TextBlock Text="The nmon_analyser_v69_2.xlsm file must be present. Browse to locate it or place it alongside this application."
                                               FontSize="11" Foreground="#3D4560"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Drop zone -->
                                <Border Grid.Row="5"
                                    x:Name="NmonDropZone"
                                    AllowDrop="True"
                                    Drop="NmonFileDropped"
                                    DragEnter="NmonDropZone_DragEnter"
                                    DragLeave="NmonDropZone_DragLeave"
                                    Background="#0D1020" BorderBrush="#1E2640"
                                    BorderThickness="1.5" CornerRadius="10" MinHeight="80" Margin="0,0,0,10">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                                        <TextBlock Text="&#x2B07;" FontSize="24" HorizontalAlignment="Center"
                                               Margin="0,0,0,8" Foreground="#2D3A5A"/>
                                        <TextBlock Text="Drag &amp; drop .nmon files here"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    </StackPanel>
                                </Border>

                                <!-- Run button row -->
                                <Grid Grid.Row="6" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                        Content="Run nmon Analyzer"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#16A34A" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold"
                                        Width="200" Height="42"
                                        Click="NmonRunAnalysis_Click"/>
                                    <TextBlock Grid.Column="1"
                                           x:Name="NmonStatusLabel"
                                           Text=""
                                           Foreground="#4A5568" FontSize="12"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center" Margin="16,0,0,0"
                                           TextWrapping="Wrap"/>
                                </Grid>

                                <!-- Log panel -->
                                <Border Grid.Row="7" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                        Padding="10,8" Visibility="Collapsed"
                                        x:Name="NmonLogPanel">
                                    <StackPanel>
                                        <ProgressBar x:Name="NmonProgress" Height="3"
                                                     Background="#1A2030" Foreground="#2563EB"
                                                     BorderThickness="0" IsIndeterminate="True"
                                                     Margin="0,0,0,6"/>
                                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="NmonLog" Text=""
                                                       Foreground="#8B93A5" FontSize="11.5"
                                                       FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══ RUN COMPARISON PAGE ══ -->
                    <Grid x:Name="PageCompare" Visibility="Collapsed">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MaxHeight="150"/>
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Run Comparison"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="First file is always the baseline. Browse or drag &amp; drop onto each row. Add more runs with + Add Run."
                                           FontSize="12.5" Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Dynamic file rows (built in code-behind) -->
                            <StackPanel Grid.Row="1"
                                        x:Name="CmpFileRowsPanel"
                                        Margin="0,0,0,8"/>

                            <!-- Add Run button -->
                            <Button Grid.Row="2"
                                    x:Name="CmpAddRunBtn"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#161B2A"
                                    BorderBrush="#252D42"
                                    BorderThickness="1"
                                    Foreground="#60A5FA"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Padding="14,0"
                                    Margin="0,0,0,16"
                                    Click="CmpAddRun_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Add Run" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Options row -->
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="File type  "
                                                   Foreground="#8B93A5" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CmpFileTypeLabel"
                                                   Text="No files selected"
                                                   Foreground="#7DD3FC" FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Comparison mode -->
                                <Border Grid.Column="1"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Mode "
                                                   Foreground="#8B93A5" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <RadioButton x:Name="CmpModeAllVsBaseline"
                                                     Content="Baseline vs each run" IsChecked="True"
                                                     Foreground="#8B93A5" FontSize="12.5"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     Margin="8,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                                     ToolTip="Baseline vs Run 2, Baseline vs Run 3, Baseline vs Run 4 …"/>
                                        <RadioButton x:Name="CmpModeSequential"
                                                     Content="Sequential (each vs previous)" IsChecked="False"
                                                     Foreground="#8B93A5" FontSize="12.5"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                                     ToolTip="Baseline vs Run 2, Run 2 vs Run 3, Run 3 vs Run 4 …"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="SLA threshold (ms) "
                                                   Foreground="#8B93A5" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <TextBox x:Name="CmpSlaTextBox"
                                                 Text="" Width="70" Height="28"
                                                 Background="#0F1117" Foreground="#E2E8F0"
                                                 BorderBrush="#2A2F3E" CaretBrush="#E2E8F0"
                                                 FontSize="12.5"
                                                 FontFamily="Segoe UI Variable, Segoe UI"
                                                 VerticalContentAlignment="Center"
                                                 Padding="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text=" — leave blank to skip"
                                                   Foreground="#3D4560" FontSize="11.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Run button -->
                            <Grid Grid.Row="5" Margin="0,16,0,0">
                                <Button Content="Run Comparison"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#7C3AED" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold"
                                        Width="190" Height="42"
                                        HorizontalAlignment="Left"
                                        Click="CmpRun_Click"/>
                            </Grid>

                            <!-- Log panel -->
                            <Border Grid.Row="6" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                    Padding="10,8" Visibility="Collapsed"
                                    x:Name="CmpLogPanel">
                                <StackPanel>
                                    <ProgressBar x:Name="CmpProgress" Height="3"
                                                 Background="#1A2030" Foreground="#7C3AED"
                                                 BorderThickness="0" IsIndeterminate="True"
                                                 Margin="0,0,0,6"/>
                                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="CmpLog" Text=""
                                                   Foreground="#8B93A5" FontSize="11.5"
                                                   FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
