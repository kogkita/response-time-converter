<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Test Utilities"
        Height="560"
        Width="860"
        MinHeight="500"
        MinWidth="740"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B93A5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2130"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1A2540"/>
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Caption button (min/max/close) -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B0251A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border gives Win11 rounded corners + shadow -->
    <Border Background="#0F1117"
            CornerRadius="12"
            BorderBrush="#2A2F3E"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="6" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Custom title bar -->
                <RowDefinition Height="40"/>
                <!-- Body -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ TITLE BAR ══════════════════════ -->
            <Border Grid.Row="0"
                    Background="#0A0D14"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App name -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <TextBlock Text="&#x23F1;"
                                   FontSize="14"
                                   Foreground="#60A5FA"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Performance Test Utilities"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#CBD5E1"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE921;"
                                Click="MinimizeWindow_Click"
                                ToolTip="Minimize"/>
                        <Button x:Name="MaxRestoreBtn"
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE922;"
                                Click="MaxRestoreWindow_Click"
                                ToolTip="Maximize"/>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;"
                                Click="CloseWindow_Click"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════ BODY ══════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#0A0D14" CornerRadius="0,0,0,12">
                    <DockPanel>

                        <Border DockPanel.Dock="Top" Padding="20,18,20,16">
                            <StackPanel>
                                <TextBlock Text="Performance Test"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Utilities"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#60A5FA"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E2130" Margin="12,0"/>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="TOOLS"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#3D4560"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,14,0,4"/>

                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                            <Button x:Name="NavConvert"
                                    Style="{StaticResource NavButtonActiveStyle}"
                                    Click="NavConvert_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Convert Response Times" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource NavButtonStyle}"
                                    IsEnabled="False"
                                    Opacity="0.35">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Coming Soon" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="v1.1.0"
                                   FontSize="11"
                                   Foreground="#2D3450"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,0,0,16"/>

                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="#1A1F2E"/>

                <!-- CONTENT -->
                <Grid Grid.Column="2" Background="#0F1117">

                    <Grid x:Name="PageConvert" Visibility="Visible">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                                <TextBlock Text="Convert Response Times"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Import a JMeter CSV report and export a formatted Excel workbook with charts."
                                           FontSize="12.5"
                                           Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Background="#161B2A"
                                        BorderBrush="#252D42"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Width="310"
                                        Height="40"
                                        Margin="0,0,10,0">
                                    <TextBox x:Name="FilePathBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#8B93A5"
                                             FontSize="12"
                                             FontFamily="Segoe UI Variable, Segoe UI"
                                             VerticalContentAlignment="Center"
                                             Padding="12,0"
                                             IsReadOnly="True"
                                             Text="No file selected…"/>
                                </Border>

                                <Button Content="Browse"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Width="88"
                                        Height="40"
                                        Click="BrowseFile_Click"/>
                            </StackPanel>

                            <Border Grid.Row="2"
                                    x:Name="DropZone"
                                    AllowDrop="True"
                                    Drop="FileDropped"
                                    DragEnter="DropZone_DragEnter"
                                    DragLeave="DropZone_DragLeave"
                                    Background="#0D1020"
                                    BorderBrush="#1E2640"
                                    BorderThickness="1.5"
                                    CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2B07;"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Foreground="#2D3A5A"/>
                                    <TextBlock Text="Drag &amp; drop your CSV file here"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Supports JMeter Aggregate Report format"
                                               FontSize="11.5"
                                               Foreground="#252D42"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Row="3"
                                    Content="Run Processing"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#16A34A"
                                    Foreground="White"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Width="180"
                                    Height="42"
                                    HorizontalAlignment="Left"
                                    Margin="0,18,0,0"
                                    Click="RunProcessing_Click"/>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>