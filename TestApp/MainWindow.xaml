                                                      Cursor="Hand"
                                                      Checked="BLGProduceGraphs_Changed"
                                                      Unchecked="BLGProduceGraphs_Changed">
                                                    <TextBlock>
                                                    <Run Text="Produce Graphs" Foreground="#A8B3C8"/>
                                                    <Run Text="  — generate Excel charts from CSV" Foreground="#6B7A99" FontSize="11.5"/>
                                                    </TextBlock>
                                                </CheckBox>
                                                <Border Width="16" Height="16" CornerRadius="8"
                                                            Background="#1E2640" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Cursor="Help">
                                                    <Border.ToolTip>
                                                        <ToolTip MaxWidth="340">
                                                            <StackPanel>
                                                                <TextBlock Text="Produce Graphs" FontWeight="SemiBold" FontSize="12" Foreground="#E2E8F0" Margin="0,0,0,4"/>
                                                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Text="After converting the .blg files to CSV, automatically generates an Excel workbook (BLG_Graphs.xlsx) containing six line charts:"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Margin="0,4,0,0" Text="• Available Memory (MB)"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Text="• % CPU"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Text="• Pages Input/sec"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Text="• Disk Queue Length"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Text="• Network Interface (Mbps)"/>
                                                                <TextBlock FontSize="11.5" Foreground="#CBD5E1" Text="• % Disk Busy"/>
                                                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Margin="0,4,0,0" Text="Each server is a separate line on every chart. Enter server labels below to give each line a readable name."/>
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                                       Foreground="#60A5FA"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Grid.Column="2"
                                               x:Name="BLGStatusLabel"
                                               Text=""
                                               Foreground="#7A8AA0" FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center" Margin="16,0,0,0"
                                               TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Server labels panel (shown when Produce Graphs is checked) -->
                                    <Border Grid.Row="1"
                                            x:Name="BLGServerLabelPanel"
                                            Visibility="Collapsed"
                                            Background="#0D1020" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="14,10" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="SERVER LABELS FOR GRAPHS"
                                                       FontSize="10" FontWeight="Bold" Foreground="#6B7A99"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,8"/>
                                            <TextBlock Text="Optional — enter a display name for each server. Defaults to file name if left blank."
                                                       FontSize="11.5" Foreground="#7A8AA0"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,10"
                                                       TextWrapping="Wrap"/>
                                            <StackPanel x:Name="BLGServerLabelInputs"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Log panel -->
                                <Border Grid.Row="7" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                        Padding="10,8" Visibility="Collapsed"
                                        x:Name="BLGLogPanel">
                                    <StackPanel>
                                        <ProgressBar x:Name="BLGProgress" Height="3"
                                                     Background="#1A2030" Foreground="#2563EB"
                                                     BorderThickness="0" IsIndeterminate="True"
                                                     Margin="0,0,0,6"/>
                                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="BLGLog" Text=""
                                                       Foreground="#A8B3C8" FontSize="11.5"
                                                       FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- ═══════════════ NMON ANALYZER PAGE ═══════════════ -->
                    <Grid x:Name="PageNmon" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="36,28,36,28">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- heading -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- browse row -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- file list -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- options -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- drop zone -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- log panel -->
                                    <RowDefinition Height="*"/>
                                    <!-- spacer -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- run button -->
                                </Grid.RowDefinitions>

                                <!-- Heading -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="nmon Analyzer"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Parse .nmon files and export formatted Excel workbooks with charts — no external tools required."
                                           FontSize="12.5" Foreground="#7A8AA0"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Browse row -->
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Height="40">
                                        <TextBlock x:Name="NmonFileCountLabel" Text="No files selected"
                                               Foreground="#A8B3C8" FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center" Padding="12,0"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB" Foreground="White"
                                        FontSize="13" FontWeight="SemiBold"
                                        Width="96" Height="40" Margin="10,0,0,0"
                                        Click="NmonBrowseFile_Click"/>
                                    <Button x:Name="NmonClearAllButton" Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151" Foreground="#B0BAC8"
                                        FontSize="12" Width="80" Height="40"
                                        Margin="8,0,0,0" Visibility="Collapsed"
                                        Click="NmonClearAll_Click"/>
                                </Grid>

                                <!-- File list -->
                                <Border Grid.Row="2" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8"
                                    MaxHeight="120" Margin="0,0,0,14" Padding="4">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="NmonFileListPanel" Margin="2"/>
                                    </ScrollViewer>
                                </Border>

                                <!-- Options -->
                                <Border Grid.Row="3" Background="#0D1020" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="OUTPUT OPTIONS"
                                               FontSize="10" FontWeight="Bold" Foreground="#6B7A99"
                                               FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Output directory -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="OUTPUT DIRECTORY  (blank = same as first input file)"
                                                       Foreground="#A8B3C8" FontSize="11"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NmonOutDirBox" Grid.Column="0"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="11" Height="32" Padding="8,0"
                                                         VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="…"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#374151" Foreground="#B0BAC8"
                                                        Width="32" Height="32" Margin="6,0,0,0"
                                                        Click="NmonOutDirBrowse_Click"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Interval filter -->
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="INTERVAL RANGE  (first / last — blank = all)"
                                                           Foreground="#A8B3C8" FontSize="11"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                    <Border Width="16" Height="16" CornerRadius="8"
                                                            Background="#1E2640" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Cursor="Help">
                                                        <Border.ToolTip>
                                                            <ToolTip MaxWidth="320">
                                                                <StackPanel>
                                                                    <TextBlock Text="What is an interval?"
                                                                               FontWeight="SemiBold" FontSize="12"
                                                                               Foreground="#E2E8F0" Margin="0,0,0,6"/>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1"
                                                                               Text="nmon captures a snapshot of system metrics at a fixed frequency (e.g. every 15 seconds). Each snapshot is one interval — numbered T0001, T0002, and so on."/>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1"
                                                                               Margin="0,6,0,0"
                                                                               Text="The total duration depends on how nmon was configured. For example, 1920 snapshots at 15s each = 8 hours of data."/>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1"
                                                                               Margin="0,6,0,0"
                                                                               Text="Use this range to analyse only a portion of the file. Leave both blank to include all intervals."/>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#60A5FA"
                                                                               Margin="0,8,0,0"
                                                                               Text="Example: enter 1 and 240 to analyse the first hour of a 15-second-interval file (240 × 15s = 1h)."/>
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                                   Foreground="#60A5FA"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NmonIntervalFirst" Grid.Column="0"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="32"
                                                         Padding="8,0" VerticalContentAlignment="Center"
                                                         ToolTip="First interval number e.g. 1"/>
                                                    <TextBlock Grid.Column="1" Text="–"
                                                           Foreground="#7A8AA0" FontSize="14"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <TextBox x:Name="NmonIntervalLast" Grid.Column="2"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="32"
                                                         Padding="8,0" VerticalContentAlignment="Center"
                                                         ToolTip="Last interval number e.g. 100"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Drop zone -->
                                <Border Grid.Row="4"
                                    x:Name="NmonDropZone"
                                    AllowDrop="True"
                                    Drop="NmonFileDropped"
                                    DragEnter="NmonDropZone_DragEnter"
                                    DragLeave="NmonDropZone_DragLeave"
                                    Background="#0D1020" BorderBrush="#1E2640"
                                    BorderThickness="1.5" CornerRadius="10" MinHeight="100" Margin="0,0,0,0">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20">
                                        <TextBlock Text="&#x2B07;" FontSize="28" HorizontalAlignment="Center"
                                               Margin="0,0,0,8" Foreground="#4A5F88"/>
                                        <TextBlock Text="Drag &amp; drop .nmon files here"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#6B7FA8"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                        <TextBlock Text="Accepts .nmon files from AIX, Linux and Power systems"
                                               FontSize="11.5" Foreground="#6B7FA8"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    </StackPanel>
                                </Border>

                                <!-- Log panel -->
                                <Border Grid.Row="5" Background="#0A0D18" BorderBrush="#1A2030"
                                        BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                        Padding="10,8" Visibility="Collapsed"
                                        x:Name="NmonLogPanel">
                                    <StackPanel>
                                        <ProgressBar x:Name="NmonProgress" Height="3"
                                                     Background="#1A2030" Foreground="#2563EB"
                                                     BorderThickness="0" IsIndeterminate="True"
                                                     Margin="0,0,0,6"/>
                                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                            <TextBlock x:Name="NmonLog" Text=""
                                                       Foreground="#A8B3C8" FontSize="11.5"
                                                       FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <!-- Run button -->
                                <Grid Grid.Row="7" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                        Content="Run nmon Analyzer"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#16A34A" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold"
                                        Width="200" Height="42"
                                        Click="NmonRunAnalysis_Click"/>
                                    <TextBlock Grid.Column="1"
                                           x:Name="NmonStatusLabel"
                                           Text=""
                                           Foreground="#7A8AA0" FontSize="12"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center" Margin="16,0,0,0"
                                           TextWrapping="Wrap"/>
                                </Grid>

                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- ══ RUN COMPARISON PAGE ══ -->
                    <Grid x:Name="PageCompare" Visibility="Collapsed">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- heading -->
                                <RowDefinition Height="Auto"/>
                                <!-- file rows -->
                                <RowDefinition Height="Auto"/>
                                <!-- add run button -->
                                <RowDefinition Height="Auto"/>
                                <!-- options -->
                                <RowDefinition Height="Auto"/>
                                <!-- log panel -->
                                <RowDefinition Height="*"/>
                                <!-- spacer -->
                                <RowDefinition Height="Auto"/>
                                <!-- run button -->
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Run Comparison"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="First file is always the baseline. Browse or drag &amp; drop onto each row. Add more runs with + Add Run."
                                           FontSize="12.5" Foreground="#7A8AA0"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Dynamic file rows (built in code-behind) -->
                            <StackPanel Grid.Row="1"
                                        x:Name="CmpFileRowsPanel"
                                        Margin="0,0,0,8"/>

                            <!-- Add Run button -->
                            <Button Grid.Row="2"
                                    x:Name="CmpAddRunBtn"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#161B2A"
                                    BorderBrush="#252D42"
                                    BorderThickness="1"
                                    Foreground="#60A5FA"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    Padding="14,0"
                                    Margin="0,0,0,16"
                                    Click="CmpAddRun_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Add Run" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Options row -->
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="File type  "
                                                   Foreground="#A8B3C8" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CmpFileTypeLabel"
                                                   Text="No files selected"
                                                   Foreground="#7DD3FC" FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Comparison mode -->
                                <Border Grid.Column="1"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Mode "
                                                   Foreground="#A8B3C8" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <Border Width="16" Height="16" CornerRadius="8"
                                                            Background="#1E2640" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Cursor="Help">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="340">
                                                    <StackPanel>
                                                        <TextBlock Text="Comparison Mode" FontWeight="SemiBold" FontSize="12" Foreground="#E2E8F0" Margin="0,0,0,4"/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Text="Controls which pairs of runs are compared in the output."/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Margin="0,6,0,0" Text="Baseline vs each run — every run is compared against Run 1. Best when you have one known-good baseline and want to track how subsequent runs changed from it."/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Margin="0,4,0,0" Text="Sequential — each run is compared to the one directly before it. Best for seeing incremental change between consecutive runs."/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                                       Foreground="#60A5FA"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <RadioButton x:Name="CmpModeAllVsBaseline"
                                                     Content="Baseline vs each run" IsChecked="True"
                                                     Foreground="#A8B3C8" FontSize="12.5"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     Margin="8,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                                     ToolTip="Baseline vs Run 2, Baseline vs Run 3, Baseline vs Run 4 …"/>
                                        <RadioButton x:Name="CmpModeSequential"
                                                     Content="Sequential (each vs previous)" IsChecked="False"
                                                     Foreground="#A8B3C8" FontSize="12.5"
                                                     FontFamily="Segoe UI Variable, Segoe UI"
                                                     Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                                     ToolTip="Baseline vs Run 2, Run 2 vs Run 3, Run 3 vs Run 4 …"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#161B2A" BorderBrush="#252D42"
                                        BorderThickness="1" CornerRadius="6"
                                        Height="42" Padding="14,0" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="SLA threshold (ms) "
                                                   Foreground="#A8B3C8" FontSize="12.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <Border Width="16" Height="16" CornerRadius="8"
                                                            Background="#1E2640" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Cursor="Help">
                                            <Border.ToolTip>
                                                <ToolTip MaxWidth="340">
                                                    <StackPanel>
                                                        <TextBlock Text="SLA Threshold" FontWeight="SemiBold" FontSize="12" Foreground="#E2E8F0" Margin="0,0,0,4"/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Text="Enter a response time limit in milliseconds. Any transaction whose P90 (90th percentile) in the compared run exceeds this value will be flagged as an SLA Breach in the output."/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Margin="0,6,0,0" Text="Leave blank to skip SLA checking entirely — no breach column will appear in the output sheets."/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#60A5FA" Margin="0,6,0,0" Text="Example: enter 3000 to flag any transaction whose P90 exceeds 3 seconds."/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="i" FontSize="10" FontWeight="Bold"
                                                                       Foreground="#60A5FA"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBox x:Name="CmpSlaTextBox"
                                                 Text="" Width="70" Height="28"
                                                 Background="#0F1117" Foreground="#E2E8F0"
                                                 BorderBrush="#2A2F3E" CaretBrush="#E2E8F0"
                                                 FontSize="12.5"
                                                 FontFamily="Segoe UI Variable, Segoe UI"
                                                 VerticalContentAlignment="Center"
                                                 Padding="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text=" — leave blank to skip"
                                                   Foreground="#6B7A99" FontSize="11.5"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Run button -->
                            <Grid Grid.Row="6" Margin="0,16,0,0">
                                <Button Content="Run Comparison"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#7C3AED" Foreground="White"
                                        FontSize="14" FontWeight="SemiBold"
                                        Width="190" Height="42"
                                        HorizontalAlignment="Left"
                                        Click="CmpRun_Click"/>
                            </Grid>

                            <!-- Log panel -->
                            <Border Grid.Row="4" Background="#0A0D18" BorderBrush="#1A2030"
                                    BorderThickness="1" CornerRadius="6" Margin="0,10,0,0"
                                    Padding="10,8" Visibility="Collapsed"
                                    x:Name="CmpLogPanel">
                                <StackPanel>
                                    <ProgressBar x:Name="CmpProgress" Height="3"
                                                 Background="#1A2030" Foreground="#7C3AED"
                                                 BorderThickness="0" IsIndeterminate="True"
                                                 Margin="0,0,0,6"/>
                                    <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="CmpLog" Text=""
                                                   Foreground="#A8B3C8" FontSize="11.5"
                                                   FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ══ SCRIPT RUNNER PAGE ══ -->
                    <Grid x:Name="PageScriptRunner" Visibility="Collapsed">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- heading -->
                                <RowDefinition Height="*"/>     <!-- two-column body -->
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="Script Runner"
                                           FontSize="21" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Save scripts to the library for one-click reuse, or load a script file directly."
                                           FontSize="12.5" Foreground="#7A8AA0"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Two-column body -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>   <!-- library panel -->
                                    <ColumnDefinition Width="12"/>    <!-- gutter -->
                                    <ColumnDefinition Width="*"/>     <!-- runner panel -->
                                </Grid.ColumnDefinitions>

                                <!-- ══ LEFT: Script Library ══ -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- library header -->
                                        <RowDefinition Height="*"/>     <!-- library list -->
                                        <RowDefinition Height="Auto"/>  <!-- add button -->
                                    </Grid.RowDefinitions>

                                    <!-- Library header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="SCRIPT LIBRARY"
                                                   FontSize="10" FontWeight="Bold" Foreground="#6B7A99"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="+ Save Current"
                                                x:Name="LibrarySaveBtn"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#1E2640" Foreground="#60A5FA"
                                                FontSize="10" FontWeight="SemiBold"
                                                Height="24" Padding="8,0"
                                                Click="LibrarySave_Click"/>
                                    </Grid>

                                    <!-- Library list -->
                                    <Border Grid.Row="1" Background="#0A0D18" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8" Padding="4">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="LibraryPanel"/>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Empty state hint -->
                                    <TextBlock Grid.Row="1"
                                               x:Name="LibraryEmptyLabel"
                                               Text="No saved scripts yet.&#x0a;Configure a script on the right&#x0a;and click + Save Current."
                                               Foreground="#3D4D70" FontSize="11.5"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               IsHitTestVisible="False"/>
                                </Grid>

                                <!-- ══ RIGHT: Runner ══ -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- script file -->
                                        <RowDefinition Height="Auto"/>  <!-- runtime + args -->
                                        <RowDefinition Height="Auto"/>  <!-- working dir + env vars -->
                                        <RowDefinition Height="*"/>     <!-- log panel -->
                                        <RowDefinition Height="Auto"/>  <!-- run button -->
                                    </Grid.RowDefinitions>

                                    <!-- Script file selector -->
                                    <Border Grid.Row="0" Background="#0D1020" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="SCRIPT FILE"
                                                       FontSize="10" FontWeight="Bold" Foreground="#6B7A99"
                                                       FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#161B2A" BorderBrush="#252D42"
                                                        BorderThickness="1" CornerRadius="6" Height="34"
                                                        AllowDrop="True"
                                                        Drop="ScriptFile_Drop"
                                                        DragEnter="ScriptFile_DragEnter"
                                                        DragLeave="ScriptFile_DragLeave">
                                                    <TextBlock x:Name="ScriptFileLabel"
                                                               Text="No script selected — browse or drag &amp; drop"
                                                               Foreground="#6B7FA8" FontSize="11.5"
                                                               FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                               VerticalAlignment="Center" Padding="10,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                                <Button Grid.Column="1" Content="Browse…"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#2563EB" Foreground="White"
                                                        FontSize="12" FontWeight="SemiBold"
                                                        Width="84" Height="34" Margin="8,0,0,0"
                                                        Click="ScriptBrowse_Click"/>
                                                <Button x:Name="ScriptFileClearBtn" Grid.Column="2"
                                                        Content="✕"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#3D1F1F" Foreground="#F87171"
                                                        FontSize="12" Width="34" Height="34"
                                                        Margin="6,0,0,0" Visibility="Collapsed"
                                                        Click="ScriptFileClear_Click"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="Detected type:"
                                                           Foreground="#6B7A99" FontSize="11"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           VerticalAlignment="Center"/>
                                                <Border x:Name="ScriptTypeBadge"
                                                        Background="#1E2640" CornerRadius="4"
                                                        Padding="8,2" Margin="8,0,0,0">
                                                    <TextBlock x:Name="ScriptTypeLabel"
                                                               Text="None"
                                                               Foreground="#60A5FA" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Runtime + Args -->
                                    <Border Grid.Row="1" Background="#0D1020" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="RUNTIME OVERRIDE"
                                                               Foreground="#6B7A99" FontSize="10" FontWeight="Bold"
                                                               FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center"/>
                                                    <Border Width="15" Height="15" CornerRadius="8"
                                                            Background="#1E2640" Margin="6,0,0,0"
                                                            VerticalAlignment="Center" Cursor="Help">
                                                        <Border.ToolTip>
                                                            <ToolTip MaxWidth="280">
                                                                <StackPanel>
                                                                    <TextBlock Text="Runtime Override" FontWeight="SemiBold" FontSize="12" Foreground="#E2E8F0" Margin="0,0,0,4"/>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#CBD5E1" Text="Leave blank to auto-detect. Override for a specific version, e.g. py -3.11 or C:\Python311\python.exe"/>
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                                                                   Foreground="#60A5FA"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBox x:Name="ScriptRuntimeBox"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="30"
                                                         Padding="8,0" VerticalContentAlignment="Center"
                                                         FontFamily="Consolas, Segoe UI Mono, Segoe UI"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="ARGUMENTS  (optional)"
                                                           Foreground="#6B7A99" FontSize="10" FontWeight="Bold"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <TextBox x:Name="ScriptArgsBox"
                                                         Background="#161B2A" Foreground="#CBD5E1"
                                                         BorderBrush="#252D42" FontSize="12" Height="30"
                                                         Padding="8,0" VerticalContentAlignment="Center"
                                                         FontFamily="Consolas, Segoe UI Mono, Segoe UI"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Working dir + Env vars -->
                                    <Border Grid.Row="2" Background="#0D1020" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="WORKING DIRECTORY  (blank = script folder)"
                                                           Foreground="#6B7A99" FontSize="10" FontWeight="Bold"
                                                           FontFamily="Segoe UI Variable, Segoe UI" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ScriptWorkDirBox" Grid.Column="0"
                                                             Background="#161B2A" Foreground="#CBD5E1"
                                                             BorderBrush="#252D42" FontSize="11" Height="30"
                                                             Padding="8,0" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="…"
                                                            Style="{StaticResource ActionButtonStyle}"
                                                            Background="#374151" Foreground="#B0BAC8"
                                                            Width="30" Height="30" Margin="6,0,0,0"
                                                            Click="ScriptWorkDir_Click"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="ENVIRONMENT VARIABLES"
                                                               Foreground="#6B7A99" FontSize="10" FontWeight="Bold"
                                                               FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center"/>
                                                    <Button Content="+ Add"
                                                            Style="{StaticResource ActionButtonStyle}"
                                                            Background="#1E2640" Foreground="#60A5FA"
                                                            FontSize="10" FontWeight="SemiBold"
                                                            Height="20" Padding="8,0" Margin="8,0,0,0"
                                                            Click="ScriptAddEnvVar_Click"/>
                                                </StackPanel>
                                                <Border Background="#0A0D18" BorderBrush="#1A2030"
                                                        BorderThickness="1" CornerRadius="6"
                                                        MaxHeight="70" Padding="4,2">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <StackPanel x:Name="ScriptEnvVarPanel"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Log panel -->
                                    <Border Grid.Row="3" Background="#060810" BorderBrush="#1A2030"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="12,10" Visibility="Collapsed"
                                            x:Name="ScriptLogPanel">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar x:Name="ScriptProgress" Height="3"
                                                             Background="#1A2030" Foreground="#16A34A"
                                                             BorderThickness="0" IsIndeterminate="True"/>
                                                <TextBlock x:Name="ScriptExitCodeLabel" Grid.Column="1"
                                                           Text="" FontSize="11" FontWeight="SemiBold"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                <Button x:Name="SaveLogAfterRunBtn" Grid.Column="2"
                                                        Content="💾 Save Log"
                                                        Visibility="Collapsed"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#1E2640" Foreground="#7DD3FC"
                                                        FontSize="11" FontWeight="SemiBold"
                                                        Height="22" Padding="8,0"
                                                        Margin="8,0,0,0"
                                                        Click="SaveLogAfterRun_Click"/>
                                            </Grid>
                                            <ScrollViewer Grid.Row="1" x:Name="ScriptLogScroller"
                                                          VerticalScrollBarVisibility="Auto">
                                                <TextBlock x:Name="ScriptLog" Text=""
                                                           Foreground="#A8B3C8" FontSize="11.5"
                                                           FontFamily="Consolas, Segoe UI Mono, Segoe UI"
                                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <!-- Run button -->
                                    <Grid Grid.Row="4" Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Save log row -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox x:Name="SaveLogCheckbox"
                                                      VerticalAlignment="Center"
                                                      Foreground="#A8B3C8" FontSize="12"
                                                      FontFamily="Segoe UI Variable, Segoe UI"
                                                      Cursor="Hand"
                                                      Checked="SaveLog_Toggled"
                                                      Unchecked="SaveLog_Toggled">
                                                <TextBlock Text="Save log to file" Foreground="#A8B3C8" FontSize="12"/>
                                            </CheckBox>
                                            <Grid x:Name="SaveLogPathPanel" Visibility="Collapsed" Margin="12,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="280"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#161B2A" BorderBrush="#252D42"
                                                        BorderThickness="1" CornerRadius="4" Height="26">
                                                    <TextBlock x:Name="SaveLogPathLabel"
                                                               Text="same folder as script"
                                                               Foreground="#4A5F88" FontSize="11"
                                                               FontFamily="Consolas, Segoe UI Mono"
                                                               VerticalAlignment="Center" Padding="8,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                                <Button Grid.Column="1" Content="…"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        Background="#374151" Foreground="#B0BAC8"
                                                        Width="26" Height="26" Margin="4,0,0,0"
                                                        Click="SaveLogBrowse_Click"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Buttons row -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ScriptRunBtn" Grid.Column="0"
                                                    Content="▶  Run Script"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Background="#16A34A" Foreground="White"
                                                    FontSize="14" FontWeight="SemiBold"
                                                    Width="160" Height="42"
                                                    Click="ScriptRun_Click"/>
                                            <Button x:Name="ScriptStopBtn" Grid.Column="1"
                                                    Content="■  Stop"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Background="#991B1B" Foreground="White"
                                                    FontSize="14" FontWeight="SemiBold"
                                                    Width="100" Height="42" Margin="10,0,0,0"
                                                    Visibility="Collapsed"
                                                    Click="ScriptStop_Click"/>
                                            <TextBlock x:Name="ScriptStatusLabel" Grid.Column="2"
                                                       Text=""
                                                       Foreground="#7A8AA0" FontSize="12"
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       VerticalAlignment="Center" Margin="16,0,0,0"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Grid>

                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>


                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
