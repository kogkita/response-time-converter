<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Test Utilities"
        Height="720"
        Width="1280"
        MinHeight="540"
        MinWidth="760"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B93A5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2130"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#1A2540"/>
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon-only remove button for file list rows -->
        <Style x:Key="RemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D1F1F"/>
                                <Setter Property="Foreground" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Caption button (min/max/close) -->
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B0251A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border gives Win11 rounded corners + shadow -->
    <Border Background="#0F1117"
            CornerRadius="12"
            BorderBrush="#2A2F3E"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="6" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════ TITLE BAR ══════════════════════ -->
            <Border Grid.Row="0"
                    Background="#0A0D14"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <TextBlock Text="&#x23F1;"
                                   FontSize="14"
                                   Foreground="#60A5FA"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Performance Test Utilities"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#CBD5E1"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE921;"
                                Click="MinimizeWindow_Click"
                                ToolTip="Minimize"/>
                        <Button x:Name="MaxRestoreBtn"
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE922;"
                                Click="MaxRestoreWindow_Click"
                                ToolTip="Maximize"/>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;"
                                Click="CloseWindow_Click"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════ BODY ══════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#0A0D14" CornerRadius="0,0,0,12">
                    <DockPanel>

                        <Border DockPanel.Dock="Top" Padding="20,18,20,16">
                            <StackPanel>
                                <TextBlock Text="Performance Test"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Utilities"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#60A5FA"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E2130" Margin="12,0"/>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="TOOLS"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#3D4560"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,14,0,4"/>

                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                            <Button x:Name="NavConvert"
                                    Style="{StaticResource NavButtonActiveStyle}"
                                    Click="NavConvert_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Convert Response Times" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="NavJTL"
                                    Style="{StaticResource NavButtonStyle}"
                                    Click="NavJTL_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C4;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="JTL File Processing" TextWrapping="Wrap" MaxWidth="130" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="v1.2.0"
                                   FontSize="11"
                                   Foreground="#2D3450"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   Margin="20,0,0,16"/>

                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="#1A1F2E"/>

                <!-- CONTENT -->
                <Grid Grid.Column="2" Background="#0F1117">

                    <Grid x:Name="PageConvert" Visibility="Visible">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <!-- Heading -->
                                <RowDefinition Height="Auto"/>
                                <!-- Browse row -->
                                <RowDefinition Height="Auto"/>
                                <!-- File list -->
                                <RowDefinition Height="Auto"/>
                                <!-- Drop zone -->
                                <RowDefinition Height="*"/>
                                <!-- Run button -->
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Convert Response Times"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Import one or more JMeter CSV(.csv) reports and export formatted Excel workbooks with charts."
                                           FontSize="12.5"
                                           Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Browse row -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- File count pill -->
                                <Border Grid.Column="0"
                                        Background="#161B2A"
                                        BorderBrush="#252D42"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="40">
                                    <TextBlock x:Name="FileCountLabel"
                                               Text="No files selected"
                                               Foreground="#8B93A5"
                                               FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center"
                                               Padding="12,0"/>
                                </Border>

                                <!-- Browse button -->
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Width="96"
                                        Height="40"
                                        Margin="10,0,0,0"
                                        Click="BrowseFile_Click"/>

                                <!-- Clear All button (hidden when no files) -->
                                <Button x:Name="ClearAllButton"
                                        Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151"
                                        Foreground="#9CA3AF"
                                        FontSize="12"
                                        Width="80"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        Click="ClearAll_Click"/>
                            </Grid>

                            <!-- Selected file list -->
                            <Border Grid.Row="2"
                                    Background="#0A0D18"
                                    BorderBrush="#1A2030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxHeight="160"
                                    Margin="0,0,0,10"
                                    Padding="4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="FileListPanel" Margin="2"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Drop zone -->
                            <Border Grid.Row="3"
                                    x:Name="DropZone"
                                    AllowDrop="True"
                                    Drop="FileDropped"
                                    DragEnter="DropZone_DragEnter"
                                    DragLeave="DropZone_DragLeave"
                                    Background="#0D1020"
                                    BorderBrush="#1E2640"
                                    BorderThickness="1.5"
                                    CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2B07;"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Foreground="#2D3A5A"/>
                                    <TextBlock Text="Drag &amp; drop CSV files here"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Multiple files supported — each gets its own Excel output"
                                               FontSize="11.5"
                                               Foreground="#252D42"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- Run button row -->
                            <!-- Run button row -->
                            <Grid Grid.Row="4" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
            Content="Run Processing"
            Style="{StaticResource ActionButtonStyle}"
            Background="#16A34A"
            Foreground="White"
            FontSize="14"
            FontWeight="SemiBold"
            Width="180"
            Height="42"
            Click="RunProcessing_Click"/>

                                <!-- Include Charts checkbox -->
                                <Border Grid.Column="1"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="IncludeChartsCheckbox"
                  IsChecked="False"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Include Charts" Foreground="#8B93A5"/>
                <Run Text="  —  add latency chart sheet to output" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>

                                <!-- Club into one file checkbox -->
                                <Border Grid.Column="2"
                                  Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="ClubOutputCheckbox"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Club into one file" Foreground="#8B93A5"/>
                <Run Text="  —  all inputs merged into a single Excel workbook" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- ══ JTL FILE PROCESSING PAGE ══ -->
                    <Grid x:Name="PageJTL" Visibility="Collapsed">
                        <Grid Margin="36,28,36,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Heading -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="JTL File Processing"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E8F0"
                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                <TextBlock Text="Import one or more JMeter JTL(.jtl) files and export formatted Excel workbooks with summary stats and charts."
                                           FontSize="12.5"
                                           Foreground="#4A5568"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Browse row -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#161B2A"
                                        BorderBrush="#252D42"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Height="40">
                                    <TextBlock x:Name="JTLFileCountLabel"
                                               Text="No files selected"
                                               Foreground="#8B93A5"
                                               FontSize="12"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               VerticalAlignment="Center"
                                               Padding="12,0"/>
                                </Border>

                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Width="96"
                                        Height="40"
                                        Margin="10,0,0,0"
                                        Click="JTLBrowseFile_Click"/>

                                <Button x:Name="JTLClearAllButton"
                                        Grid.Column="2"
                                        Content="Clear All"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#374151"
                                        Foreground="#9CA3AF"
                                        FontSize="12"
                                        Width="80"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        Click="JTLClearAll_Click"/>
                            </Grid>

                            <!-- Selected file list -->
                            <Border Grid.Row="2"
                                    Background="#0A0D18"
                                    BorderBrush="#1A2030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxHeight="160"
                                    Margin="0,0,0,10"
                                    Padding="4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="JTLFileListPanel" Margin="2"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Drop zone -->
                            <Border Grid.Row="3"
                                    x:Name="JTLDropZone"
                                    AllowDrop="True"
                                    Drop="JTLFileDropped"
                                    DragEnter="JTLDropZone_DragEnter"
                                    DragLeave="JTLDropZone_DragLeave"
                                    Background="#0D1020"
                                    BorderBrush="#1E2640"
                                    BorderThickness="1.5"
                                    CornerRadius="10">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#x2B07;"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Foreground="#2D3A5A"/>
                                    <TextBlock Text="Drag &amp; drop JTL files here"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#3D4D70"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                    <TextBlock Text="Supports .jtl JMeter result files — multiple files get their own Excel output"
                                               FontSize="11.5"
                                               Foreground="#252D42"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- Run button row -->
                            <!-- Run button row -->
                            <Grid Grid.Row="4" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
            Content="Run Processing"
            Style="{StaticResource ActionButtonStyle}"
            Background="#16A34A"
            Foreground="White"
            FontSize="14"
            FontWeight="SemiBold"
            Width="180"
            Height="42"
            Click="JTLRunProcessing_Click"/>

                                <!-- Include Charts checkbox -->
                                <Border Grid.Column="1"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="JTLIncludeChartsCheckbox"
                  IsChecked="False"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Include Charts" Foreground="#8B93A5"/>
                <Run Text="  —  add latency chart sheet to output" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>

                                <!-- Club into one file checkbox -->
                                <Border Grid.Column="2"
            Background="#161B2A"
            BorderBrush="#252D42"
            BorderThickness="1"
            CornerRadius="6"
            Height="42"
            Margin="12,0,0,0"
            Padding="14,0">
                                    <CheckBox x:Name="JTLClubOutputCheckbox"
                  VerticalAlignment="Center"
                  Foreground="#8B93A5"
                  FontSize="12.5"
                  FontFamily="Segoe UI Variable, Segoe UI"
                  Cursor="Hand">
                                        <TextBlock>
                <Run Text="Club into one file" Foreground="#8B93A5"/>
                <Run Text="  —  all inputs merged into a single Excel workbook" Foreground="#3D4560" FontSize="11.5"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>