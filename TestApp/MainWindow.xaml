<Window x:Class="ResponseTimeConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Response Time Converter"
        Height="350"
        Width="520"
        Background="#F4F6F8">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Response Time Converter"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- File selector -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,15">

            <TextBox Name="FilePathBox"
                     Width="320"
                     Height="34"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="10"
                     Margin="0,0,10,0"
                     Background="White"
                     BorderBrush="#D0D5DD"
                     BorderThickness="1"
                     IsReadOnly="True"/>

            <Button Content="Browse"
                    Width="100"
                    Height="34"
                    FontSize="14"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BrowseFile_Click"/>

        </StackPanel>

        <!-- Drag Drop Area -->
        <Border Grid.Row="2"
                AllowDrop="True"
                Drop="FileDropped"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="2"
                CornerRadius="12"
                Padding="20"
                Margin="0,10">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="Drag and drop your file here"
                           FontSize="16"
                           Foreground="#475569"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="or use the browse button above"
                           FontSize="13"
                           Foreground="#94A3B8"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

        <!-- Run Button -->
        <Button Grid.Row="3"
                Content="Run Processing"
                Width="180"
                Height="42"
                FontSize="15"
                FontWeight="SemiBold"
                Background="#22C55E"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Click="RunProcessing_Click"/>

    </Grid>

</Window>